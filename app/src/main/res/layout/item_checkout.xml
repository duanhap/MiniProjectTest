<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardCheckoutItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/colorDivider"
    app:cardBackgroundColor="@color/colorSurface"
    tools:ignore="HardcodedText">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivCheckoutThumb"
            android:layout_width="68dp"
            android:layout_height="68dp"
            android:scaleType="centerCrop"
            android:background="#F3F4F6"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Product name -->
        <TextView
            android:id="@+id/tvCheckoutName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            tools:text="Áo Thun Trắng"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnSurface"
            android:maxLines="2"
            android:ellipsize="end"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivCheckoutThumb"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Quantity -->
        <TextView
            android:id="@+id/tvCheckoutQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="6dp"
            tools:text="Qty: 2"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:letterSpacing="0.01"
            app:layout_constraintTop_toBottomOf="@id/tvCheckoutName"
            app:layout_constraintStart_toEndOf="@id/ivCheckoutThumb" />

        <!-- Line price -->
        <TextView
            android:id="@+id/tvCheckoutPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="$299.00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
